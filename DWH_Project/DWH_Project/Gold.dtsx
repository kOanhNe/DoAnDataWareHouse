      <DTS:ObjectData>
        <DTS:ConnectionManager
          DTS:ConnectRetryCount="1"
          DTS:ConnectRetryInterval="5"
          DTS:ConnectionString="Data Source=localhost;Initial Catalog=DataSupplyChain;Provider=MSOLEDBSQL.1;Integrated Security=SSPI;Auto Translate=False;Application Name=SSIS-Gold-{D94A5E3C-AFCA-4D2B-B797-CDF5E9F6B4C1};" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Create Gold Schema and Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{7F4B18B2-31F9-465C-A810-E45D5A2346FA}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create Gold Schema and Tables"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D94A5E3C-AFCA-4D2B-B797-CDF5E9F6B4C1}"
          SQLTask:SqlStatementSource="IF SCHEMA_ID('gold') IS NULL EXEC('CREATE SCHEMA gold');&#xA;&#xA;IF OBJECT_ID('gold.dim_customer','U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE gold.dim_customer (&#xA;        customer_id INT NOT NULL PRIMARY KEY,&#xA;        customer_fname VARCHAR(100) NULL,&#xA;        customer_lname VARCHAR(100) NULL,&#xA;        customer_email VARCHAR(100) NULL,&#xA;        customer_segment VARCHAR(50) NULL,&#xA;        customer_city VARCHAR(100) NULL,&#xA;        customer_state VARCHAR(20) NULL,&#xA;        customer_country VARCHAR(100) NULL,&#xA;        customer_street VARCHAR(200) NULL,&#xA;        customer_zipcode VARCHAR(20) NULL&#xA;    );&#xA;END;&#xA;&#xA;IF OBJECT_ID('gold.dim_product','U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE gold.dim_product (&#xA;        product_card_id INT NOT NULL PRIMARY KEY,&#xA;        product_name VARCHAR(255) NULL,&#xA;        product_price FLOAT NULL,&#xA;        product_status INT NULL,&#xA;        product_category_id INT NULL,&#xA;        category_name VARCHAR(255) NULL&#xA;    );&#xA;END;&#xA;&#xA;IF OBJECT_ID('gold.dim_date','U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE gold.dim_date (&#xA;        date_key INT NOT NULL PRIMARY KEY,&#xA;        full_date DATE NOT NULL,&#xA;        [year] INT NOT NULL,&#xA;        [quarter] INT NOT NULL,&#xA;        [month] INT NOT NULL,&#xA;        [day] INT NOT NULL&#xA;    );&#xA;END;&#xA;&#xA;IF OBJECT_ID('gold.fact_sales','U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE gold.fact_sales (&#xA;        order_item_id INT NOT NULL PRIMARY KEY,&#xA;        order_id INT NULL,&#xA;        order_date_key INT NULL,&#xA;        customer_id INT NULL,&#xA;        product_card_id INT NULL,&#xA;        shipping_mode VARCHAR(50) NULL,&#xA;        delivery_status VARCHAR(50) NULL,&#xA;        quantity INT NULL,&#xA;        product_price FLOAT NULL,&#xA;        discount_amount FLOAT NULL,&#xA;        discount_rate FLOAT NULL,&#xA;        line_total FLOAT NULL,&#xA;        profit_ratio FLOAT NULL,&#xA;        order_profit_per_order FLOAT NULL,&#xA;        late_delivery_risk INT NULL,&#xA;        days_for_shipping_real INT NULL,&#xA;        days_for_shipment_scheduled INT NULL&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Gold Dim Customer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{57F3AE38-9CA0-4E3A-8E9A-E63AA4E32735}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Gold Dim Customer"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D94A5E3C-AFCA-4D2B-B797-CDF5E9F6B4C1}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE gold.dim_customer;&#xA;&#xA;INSERT INTO gold.dim_customer&#xA;(&#xA;    customer_id,&#xA;    customer_fname,&#xA;    customer_lname,&#xA;    customer_email,&#xA;    customer_segment,&#xA;    customer_city,&#xA;    customer_state,&#xA;    customer_country,&#xA;    customer_street,&#xA;    customer_zipcode&#xA;)&#xA;SELECT&#xA;    customer_id,&#xA;    customer_fname,&#xA;    customer_lname,&#xA;    customer_email,&#xA;    customer_segment,&#xA;    customer_city,&#xA;    customer_state,&#xA;    customer_country,&#xA;    customer_street,&#xA;    customer_zipcode&#xA;FROM silver.customer;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Gold Dim Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{06E8FDBE-53BE-4B8A-ACDE-6868A69057B8}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Gold Dim Date"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D94A5E3C-AFCA-4D2B-B797-CDF5E9F6B4C1}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE gold.dim_date;&#xA;&#xA;INSERT INTO gold.dim_date&#xA;(&#xA;    date_key,&#xA;    full_date,&#xA;    [year],&#xA;    [quarter],&#xA;    [month],&#xA;    [day]&#xA;)&#xA;SELECT DISTINCT&#xA;    CAST(CONVERT(VARCHAR(8), TRY_CONVERT(DATE, order_date_dateorders), 112) AS INT) AS date_key,&#xA;    TRY_CONVERT(DATE, order_date_dateorders) AS full_date,&#xA;    YEAR(TRY_CONVERT(DATE, order_date_dateorders)) AS [year],&#xA;    DATEPART(QUARTER, TRY_CONVERT(DATE, order_date_dateorders)) AS [quarter],&#xA;    MONTH(TRY_CONVERT(DATE, order_date_dateorders)) AS [month],&#xA;    DAY(TRY_CONVERT(DATE, order_date_dateorders)) AS [day]&#xA;FROM silver.orders&#xA;WHERE TRY_CONVERT(DATE, order_date_dateorders) IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Gold Dim Product"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{E0C6059A-6DBF-4B11-A84C-BB2EF5E8749D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Gold Dim Product"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D94A5E3C-AFCA-4D2B-B797-CDF5E9F6B4C1}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE gold.dim_product;&#xA;&#xA;INSERT INTO gold.dim_product&#xA;(&#xA;    product_card_id,&#xA;    product_name,&#xA;    product_price,&#xA;    product_status,&#xA;    product_category_id,&#xA;    category_name&#xA;)&#xA;SELECT&#xA;    p.product_card_id,&#xA;    p.product_name,&#xA;    p.product_price,&#xA;    p.product_status,&#xA;    p.product_category_id,&#xA;    c.category_name&#xA;FROM silver.product p&#xA;LEFT JOIN silver.category c&#xA;    ON p.product_category_id = c.category_id;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Gold Fact Sales"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{DE69E6FA-7C78-438E-BCF9-AF5411DC7D9D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Gold Fact Sales"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D94A5E3C-AFCA-4D2B-B797-CDF5E9F6B4C1}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE gold.fact_sales;&#xA;&#xA;INSERT INTO gold.fact_sales&#xA;(&#xA;    order_item_id,&#xA;    order_id,&#xA;    order_date_key,&#xA;    customer_id,&#xA;    product_card_id,&#xA;    shipping_mode,&#xA;    delivery_status,&#xA;    quantity,&#xA;    product_price,&#xA;    discount_amount,&#xA;    discount_rate,&#xA;    line_total,&#xA;    profit_ratio,&#xA;    order_profit_per_order,&#xA;    late_delivery_risk,&#xA;    days_for_shipping_real,&#xA;    days_for_shipment_scheduled&#xA;)&#xA;SELECT&#xA;    oi.order_item_id,&#xA;    oi.order_id,&#xA;    CAST(CONVERT(VARCHAR(8), TRY_CONVERT(DATE, o.order_date_dateorders), 112) AS INT) AS order_date_key,&#xA;    o.order_customer_id AS customer_id,&#xA;    oi.order_item_cardprod_id AS product_card_id,&#xA;    s.shipping_mode,&#xA;    s.delivery_status,&#xA;    oi.order_item_quantity AS quantity,&#xA;    oi.order_item_product_price AS product_price,&#xA;    oi.order_item_discount AS discount_amount,&#xA;    oi.order_item_discount_rate AS discount_rate,&#xA;    oi.order_item_total AS line_total,&#xA;    oi.order_item_profit_ratio AS profit_ratio,&#xA;    o.order_profit_per_order,&#xA;    s.late_delivery_risk,&#xA;    s.days_for_shipping_real,&#xA;    s.days_for_shipment_scheduled&#xA;FROM silver.order_items oi&#xA;LEFT JOIN silver.orders o&#xA;    ON oi.order_id = o.order_id&#xA;LEFT JOIN silver.shipping s&#xA;    ON oi.order_id = s.order_id;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
