              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[bronze].[orders]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
    CAST(b.order_id AS INT) AS order_id,
    TRY_CAST(b.order_date_dateorders AS DATETIME) AS order_date_dateorders,
    CAST(b.order_customer_id AS INT) AS order_customer_id,
    CAST(UPPER(LTRIM(RTRIM(b.order_status))) AS VARCHAR(50)) AS order_status,
    CAST(LTRIM(RTRIM(b.order_city)) AS VARCHAR(100)) AS order_city,
    CAST(LTRIM(RTRIM(b.order_state)) AS VARCHAR(100)) AS order_state,
    CAST(LTRIM(RTRIM(b.order_country)) AS VARCHAR(100)) AS order_country,
    CAST(LTRIM(RTRIM(b.order_region)) AS VARCHAR(100)) AS order_region,
    CAST(LTRIM(RTRIM(b.market)) AS VARCHAR(50)) AS market,
    CAST(b.order_profit_per_order AS FLOAT) AS order_profit_per_order
FROM bronze.orders b
WHERE TRY_CAST(b.order_id AS BIGINT) IS NOT NULL
  AND TRY_CAST(b.order_id AS BIGINT) &gt; ?
  AND TRY_CAST(b.order_id AS BIGINT) &lt;= ?
  AND NOT EXISTS (
      SELECT 1
      FROM silver.orders s
      WHERE s.order_id = TRY_CAST(b.order_id AS INT)
  );</property>
