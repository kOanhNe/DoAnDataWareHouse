              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[bronze].[customer]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
    CAST(customer_id AS INT)                    AS customer_id,
    LTRIM(RTRIM(customer_fname))                AS customer_fname,
    LTRIM(RTRIM(customer_lname))                AS customer_lname,
    LOWER(LTRIM(RTRIM(customer_email)))         AS customer_email,
    LTRIM(RTRIM(customer_segment))              AS customer_segment,
    LTRIM(RTRIM(customer_city))                 AS customer_city,
    CAST(LTRIM(RTRIM(customer_state)) AS VARCHAR(20)) AS customer_state,
    LTRIM(RTRIM(customer_country))              AS customer_country,
    LTRIM(RTRIM(customer_street))               AS customer_street,
    CAST(ISNULL(LTRIM(RTRIM(customer_zipcode)), 'Unknown') AS VARCHAR(20)) AS customer_zipcode
FROM bronze.customer
WHERE ISNUMERIC(customer_id) = 1</property>
